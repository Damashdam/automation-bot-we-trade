# ─────────────────────────────────────────────
# Source Monitoring
# ─────────────────────────────────────────────
TARGET_X_USERNAME=StockMKTNewz
CHECK_INTERVAL_MINUTES=5
DRY_RUN=true

# ─────────────────────────────────────────────
# Telegram
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Add the bot to your channel/group, then get the chat ID:
#    - For a private chat: message the bot, then open:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#    - For a channel: add bot as admin, use @username or numeric ID (e.g. -100xxxxxxxxxx)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here

# ─────────────────────────────────────────────
# WhatsApp Provider (optional — Telegram is now the default)
# Options: 'meta' (WhatsApp Cloud API) or 'twilio'
# ─────────────────────────────────────────────
WHATSAPP_PROVIDER=meta

# --- Meta / WhatsApp Cloud API ---------------
# 1. Create a Meta Developer app at https://developers.facebook.com
# 2. Add the WhatsApp product
# 3. Get your Phone Number ID and a permanent access token
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890

# The destination WhatsApp number (international format, no + sign for Meta API)
# Example for Israel: 972501234567
TARGET_WHATSAPP_NUMBER=972501234567

# --- Twilio (alternative) --------------------
# Sandbox number is +14155238886 for testing
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ─────────────────────────────────────────────
# WhatsApp Web (whatsapp-web.js linked device)
# ─────────────────────────────────────────────
WHATSAPP_GROUP_NAME=עדכונים של הקהילה🧠
WHATSAPP_GROUP_ID=120363142510282822@g.us
WHATSAPP_GROUP_INVITE_URL=https://chat.whatsapp.com/XXXX
WHATSAPP_PHONE_NUMBER=972535571718
# production: true | local QR window: false
WA_HEADLESS=true

# ─────────────────────────────────────────────
# Deploy / paths
# ─────────────────────────────────────────────
DATA_DIR=./data
PORT=8080
# CHROME_PATH=/usr/bin/chromium

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=./data/wetrade.db

# ─────────────────────────────────────────────
# Logging  (error | warn | info | debug)
# ─────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Dry run — log messages to console instead of sending to WhatsApp
# ─────────────────────────────────────────────
DRY_RUN=false
